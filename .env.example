# ───────────────────────────────────────────────────────────────────────────
# Database — Neon Postgres (https://neon.tech)
# Create a project, copy the POOLED connection string, paste here.
# Example: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
#
# On Vercel: set this in Project Settings → Environment Variables for
# Production, Preview, and Development. Use Neon's pooled URL (the one
# ending in `-pooler.…`) so serverless invocations don't exhaust connections.
# ───────────────────────────────────────────────────────────────────────────
DATABASE_URL=

# ───────────────────────────────────────────────────────────────────────────
# BetterAuth (https://www.better-auth.com)
# Generate a 32+ char secret: openssl rand -base64 32
# On Vercel: generate a NEW secret for production — don't reuse the dev one.
# ───────────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=

# Base URL of the deployment. Used by BetterAuth to build callback/redirect
# URLs and to validate request origins.
#   Local dev:  http://localhost:3000
#   Vercel:     https://<your-project>.vercel.app  (or your custom domain)
# Set per-environment in Vercel; do NOT commit a production value here.
BETTER_AUTH_URL=http://localhost:3000
